{
  "name": "orkis",
  "version": "0.0.0",
  "private": true,
  "description": "AI Agent Orchestrator",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/watch.ts",
    "build": "pnpm -r build",
    "start": "electron apps/electron",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm -r --include-workspace-root typecheck",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
