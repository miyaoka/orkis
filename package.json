{
  "name": "gozd",
  "version": "0.0.0",
  "private": true,
  "description": "AI Agent Orchestrator",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"pnpm --filter @gozd/renderer dev\" \"pnpm --filter @gozd/desktop dev\"",
    "build": "pnpm -r build",
    "open": "open apps/desktop/build/stable-macos-arm64/gozd.app",
    "format": "oxfmt .",
    "lint": "oxlint --type-aware",
    "fix": "oxfmt '!apps/**' '!packages/**'",
    "lint:all": "pnpm -r --include-workspace-root --if-present --no-bail --aggregate-output --reporter=append-only lint",
    "fix:all": "pnpm -r --include-workspace-root --if-present --no-bail --aggregate-output --reporter=append-only fix",
    "test:all": "pnpm -r --if-present --no-bail --aggregate-output --reporter=append-only test",
    "typecheck:all": "pnpm -r --include-workspace-root --if-present typecheck",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "concurrently": "9.2.1",
    "knip": "^6.0.3",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "vite": "catalog:"
  }
}
