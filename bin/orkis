#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
SOCKET_PATH="/tmp/orkis.sock"
CLI="${ROOT_DIR}/apps/cli/src/index.ts"

# ソケットに接続できるか確認（接続成功=アプリ起動済み）
is_app_running() {
  [[ -S "${SOCKET_PATH}" ]] || return 1

  # ソケットファイルがあっても実際に接続できるか確認
  if ! nc -zU "${SOCKET_PATH}" 2>/dev/null; then
    # 残骸ソケットを削除
    rm -f "${SOCKET_PATH}"
    return 1
  fi
  return 0
}

# アプリ未起動なら起動する（hook コマンドを除く）
should_launch_app() {
  # アプリが起動済みなら起動不要
  is_app_running && return 1

  # open コマンド（デフォルト）以外はアプリ起動不要
  [[ "${1:-}" == "hook" || "${1:-}" == -* ]] && return 1

  return 0
}

launch_app() {
  local build_dir="${ROOT_DIR}/apps/desktop/build"

  if [[ ! -d "${build_dir}" ]]; then
    echo "未ビルドのためビルドを実行します..." >&2
    (cd "${ROOT_DIR}" && pnpm build) || return 1
  fi

  # ビルド済みの Electrobun アプリをバックグラウンドで起動
  export ORKIS_PROJECT_ROOT="${PWD}"
  (cd "${ROOT_DIR}" && pnpm --filter @orkis/desktop start) &>/dev/null &
  disown

  # ソケットが立ち上がるまで待つ
  local max_wait=10
  local waited=0
  while [[ ! -S "${SOCKET_PATH}" ]] && (( waited < max_wait )); do
    sleep 0.2
    (( waited++ ))
  done

  if [[ ! -S "${SOCKET_PATH}" ]]; then
    echo "アプリの起動がタイムアウトしました" >&2
    return 1
  fi
}

if should_launch_app "$@"; then
  launch_app || exit $?
fi

exec bun "${CLI}" "$@"
