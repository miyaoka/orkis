{
  "name": "@gozd/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "GOZD_DEV_PROJECT_ROOT=$PWD pnpm exec electrobun dev",
    "build": "unset GOZD_DEV_PROJECT_ROOT && pnpm exec electrobun build --env=stable",
    "typecheck": "tsgo --noEmit",
    "test": "bun test --run",
    "lint": "oxlint --type-aware",
    "fix": "oxlint --type-aware --fix && oxfmt ."
  },
  "dependencies": {
    "@gozd/cli": "workspace:*",
    "@gozd/renderer": "workspace:*",
    "@gozd/rpc": "workspace:*",
    "@gozd/shared": "workspace:*",
    "electrobun": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  }
}
