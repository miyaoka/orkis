#!/usr/bin/env bash

# .app 内のパス解決
# 配置先: orkis.app/Contents/Resources/app/bin/orkis
# シンボリックリンクを解決して実体のディレクトリを取得
SOURCE="$0"
while [[ -L "${SOURCE}" ]]; do
  DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
APP_RESOURCES="${SCRIPT_DIR}/.."
APP_CONTENTS="${APP_RESOURCES}/../.."
BUN="${APP_CONTENTS}/MacOS/bun"
CLI="${APP_RESOURCES}/cli/index.js"
APP_BUNDLE="${APP_CONTENTS}/.."
SOCKET_PATH="${TMPDIR:-/tmp}/orkis-stable.sock"

is_app_running() {
  [[ -S "${SOCKET_PATH}" ]] || return 1

  # ソケットファイルがあっても実際に接続できるか確認（残骸検出）
  if ! echo "" | nc -U "${SOCKET_PATH}" 2>/dev/null; then
    rm -f "${SOCKET_PATH}"
    return 1
  fi
  return 0
}

# open コマンド（デフォルト）以外はアプリ起動不要
should_launch_app() {
  is_app_running && return 1
  [[ "${1:-}" == "hook" || "${1:-}" == -* ]] && return 1
  return 0
}

if should_launch_app "$@"; then
  # cold start: CLI に launch request ファイルを書かせてからアプリを起動
  ORKIS_COLD_START=1 "${BUN}" "${CLI}" "$@" || exit $?
  open "${APP_BUNDLE}"
  exit $?
fi

# warm start: ソケット経由で既存アプリに送信
exec "${BUN}" "${CLI}" "$@"
