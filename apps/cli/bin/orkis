#!/usr/bin/env bash

# .app 内のパス解決
# 配置先: orkis.app/Contents/Resources/app/bin/orkis
# シンボリックリンクを解決して実体のディレクトリを取得
SOURCE="$0"
while [[ -L "${SOURCE}" ]]; do
  DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
APP_RESOURCES="${SCRIPT_DIR}/.."
APP_CONTENTS="${APP_RESOURCES}/../.."
BUN="${APP_CONTENTS}/MacOS/bun"
CLI="${APP_RESOURCES}/cli/index.js"
APP_BUNDLE="${APP_CONTENTS}/.."
## stable → dev の順で探す（socket-client.ts と同じ優先順）
SOCKET_CANDIDATES=("/tmp/orkis-stable.sock" "/tmp/orkis-dev.sock")

## 接続可能なソケットを探して ACTIVE_SOCKET に設定する（削除なし）
try_connect() {
  ACTIVE_SOCKET=""
  for sock in "${SOCKET_CANDIDATES[@]}"; do
    [[ -S "${sock}" ]] || continue

    if nc -zU "${sock}" 2>/dev/null; then
      ACTIVE_SOCKET="${sock}"
      return 0
    fi
  done
  return 1
}

## 起動前の残骸ソケットを掃除してから接続を試みる
is_app_running() {
  for sock in "${SOCKET_CANDIDATES[@]}"; do
    [[ -S "${sock}" ]] || continue

    if nc -zU "${sock}" 2>/dev/null; then
      ACTIVE_SOCKET="${sock}"
      return 0
    fi
    # 起動前なので接続できないソケットは残骸とみなして削除
    rm -f "${sock}"
  done
  return 1
}

# open コマンド（デフォルト）以外はアプリ起動不要
should_launch_app() {
  is_app_running && return 1
  [[ "${1:-}" == "hook" || "${1:-}" == -* ]] && return 1
  return 0
}

launch_app() {
  open "${APP_BUNDLE}"

  # ソケットが接続可能になるまで待つ（起動中なので削除しない）
  local max_wait=10
  local waited=0
  while ! try_connect && (( waited < max_wait )); do
    sleep 0.2
    (( waited++ ))
  done

  if [[ -z "${ACTIVE_SOCKET}" ]]; then
    echo "アプリの起動がタイムアウトしました" >&2
    return 1
  fi
}

if should_launch_app "$@"; then
  launch_app || exit $?
fi

exec "${BUN}" "${CLI}" "$@"
